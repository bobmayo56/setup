#!/bin/sh
set -eu

PY="${PYTHON:-python3}"
N="${1:-100000000}"

"$PY" - "$N" <<'PY'
import os, sys, time, multiprocessing as mp

n = int(sys.argv[1])
workers = os.cpu_count() or 1

def work(n):
    s = 0
    for i in range(n):
        s += (i * i) % 97
    return s

t = time.perf_counter()
work(n)
single = time.perf_counter() - t

base = n // workers
rem = n % workers
chunks = [base + (1 if i < rem else 0) for i in range(workers)]

t = time.perf_counter()
with mp.Pool(workers) as p:
    p.map(work, chunks)
multi = time.perf_counter() - t

print(f"Python integer loop single-core: {single:.2f} sec")
print(f"Python integer loop multi-core:  {multi:.2f} sec using {workers} workers")
print(f"Speedup:            {single / multi:.2f}x")
PY

