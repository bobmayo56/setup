#!/bin/sh
# usage: send-email [--subject "text"] [--html] to@example.com < body.txt

HTML=false

while [ $# -gt 0 ]; do
  case "$1" in
    --subject) SUBJECT="$2"; shift 2 ;;
    --html)    HTML=true;     shift ;;
    --*) echo "Unknown option: $1"; exit 1 ;;
    *) TO="$1"; shift ;;
  esac
done

: ${TO:?to address required}
: ${SUBJECT:?--subject required}
: ${RESEND_API_KEY:?RESEND_API_KEY not set}

BODY=$(cat)

if [ "$HTML" = true ]; then
  PAYLOAD=$(jq -n \
    --arg to "$TO" \
    --arg subject "$SUBJECT" \
    --arg body "$BODY" \
    '{from: "do-not-reply@claude.project255.com", to: [$to], subject: $subject, html: $body}')
else
  PAYLOAD=$(jq -n \
    --arg to "$TO" \
    --arg subject "$SUBJECT" \
    --arg body "$BODY" \
    '{from: "do-not-reply@claude.project255.com", to: [$to], subject: $subject, text: $body}')
fi

curl -X POST https://api.resend.com/emails \
  -H "Authorization: Bearer $RESEND_API_KEY" \
  -H "Content-Type: application/json" \
  -d "$PAYLOAD"

echo "\n"
