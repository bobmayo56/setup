alias encrypt='openssl enc -e -a -aes-256-cbc'
alias decrypt='openssl enc -d -a -aes-256-cbc'
if ls --color=auto &>/dev/null 2>&1; then
    alias ls='ls --color=auto'
else
    alias ls='ls -G'
fi
alias lf='ls -F'
alias ll='ls -l'
alias la='ls -a'
alias lla='ls -la'
alias fulldev='ssh -i ~/.ssh/id_ed25519_aws_2026 ubuntu@vps-97830af0.vps.ovh.us'
alias hi='history 50'
alias clr='echo;echo;yes "============================= `date` =============================" | head -203;echo'
alias pip3='python3 -m pip'
